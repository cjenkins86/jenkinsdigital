---
import type { CollectionEntry } from "astro:content";

interface Props {
    post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
---

<div class="flex flex-col rounded-lg shadow-lg overflow-hidden">
    <div class="flex-1 bg-white p-6 flex flex-col justify-between">
        <div class="flex-1">
            <p class="text-sm font-medium text-primary">
                <a href={`/strategy-lab/${post.slug}`} class="hover:underline">
                    {post.data.category || "Uncategorized"}
                </a>
            </p>
            <a href={`/strategy-lab/${post.slug}`} class="block mt-2">
                <p class="text-xl font-semibold text-gray-900">
                    {post.data.title}
                </p>
                <p class="mt-3 text-base text-gray-500">
                    {post.data.description}
                </p>
            </a>
        </div>
        <div class="mt-6 flex items-center">
            <div class="flex-shrink-0">
                <span class="sr-only"
                    >{post.data.author || "Unknown Author"}</span
                >
                <div
                    class="h-10 w-10 rounded-full bg-gray-200 flex items-center justify-center text-gray-500 font-bold"
                >
                    {post.data.author?.charAt(0) || "U"}
                </div>
            </div>
            <div class="ml-3">
                <p class="text-sm font-medium text-gray-900">
                    {post.data.author}
                </p>
                <div class="flex space-x-1 text-sm text-gray-500">
                    <time datetime={post.data.pubDate.toISOString()}>
                        {
                            post.data.pubDate.toLocaleDateString("en-US", {
                                year: "numeric",
                                month: "long",
                                day: "numeric",
                            })
                        }
                    </time>
                </div>
            </div>
        </div>
    </div>
</div>
