---
const navItems = [{ href: "/blog", text: "Blog" }];
---

<header class="bg-white shadow-sm sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-16 items-center">
      <div class="flex-shrink-0 flex items-center">
        <a href="/" class="text-2xl font-bold text-primary">Jenkins Digital</a>
      </div>
      <nav id="mobile-menu" class="hidden absolute top-16 left-0 w-full bg-white shadow-md sm:shadow-none sm:static sm:bg-transparent sm:w-auto p-4 sm:p-0 sm:flex sm:space-x-8 flex-col sm:flex-row gap-4">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class="text-gray-700 hover:text-primary px-3 py-2 rounded-md text-sm font-medium transition-colors"
            >
              {item.text}
            </a>
          ))
        }
      </nav>
      <!-- Mobile menu button placeholder - can be expanded later -->
      <div class="sm:hidden">
        <button
          id="mobile-menu-button"
          type="button"
          class="text-gray-500 hover:text-primary focus:outline-none"
        >
          <span class="sr-only">Open main menu</span>
          <svg
            class="h-6 w-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-button");
  const menu = document.getElementById("mobile-menu");
  if (btn && menu) {
    btn.addEventListener("click", () => {
      menu.classList.toggle("hidden");
    });
  }
</script>
