---
interface CTAButton {
    text: string;
    href: string;
}

interface CTAButton {
    text: string;
    href: string;
}

const headline = "Ready to fix the machine?";
const bodyText =
    "Stop wasting money on broken marketing. Let us build a system that actually builds profit.";
const ctas: CTAButton[] = [
    { text: "Apply for May →", href: "/apply" },
    { text: "Join the Waitlist", href: "#" },
];
---

<section class="relative py-24 bg-[#1E2A38] overflow-hidden">
    <!-- Dot pattern background -->
    <div class="absolute inset-0 opacity-10">
        <svg
            class="h-full w-full"
            fill="none"
            viewBox="0 0 100 100"
            preserveAspectRatio="none"
        >
            <pattern
                id="dot-pattern"
                x="0"
                y="0"
                width="20"
                height="20"
                patternUnits="userSpaceOnUse"
            >
                <circle
                    cx="2"
                    cy="2"
                    r="1"
                    class="text-white"
                    fill="currentColor"></circle>
            </pattern>
            <rect width="100%" height="100%" fill="url(#dot-pattern)"></rect>
        </svg>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl mb-6">
            {headline}
        </h2>
        <p class="text-xl text-gray-300 max-w-2xl mx-auto mb-10">
            {bodyText}
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
            {
                ctas &&
                    ctas.map((cta, index) => (
                        <div class="mt-3 sm:mt-0 sm:ml-3 first:ml-0 first:mt-0 rounded-md shadow">
                            <a
                                href={cta.href}
                                class={`inline-flex items-center justify-center px-8 py-3 border text-base font-medium rounded-md md:py-4 md:text-lg md:px-10 transition-colors ${
                                    index === 0
                                        ? "border-transparent text-white bg-orange-500 hover:bg-orange-600 shadow-xl"
                                        : "border-gray-500 text-white bg-transparent hover:bg-gray-800"
                                }`}
                            >
                                {cta.text}
                            </a>
                        </div>
                    ))
            }
        </div>
        <p class="mt-8 text-sm text-gray-400 max-w-lg mx-auto">
            I read every application. I only take jobs where I know I can win
            for you. If we are a bad fit, I will tell you the truth right away.
        </p>
    </div>
</section>
