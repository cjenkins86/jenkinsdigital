---
interface Feature {
    icon: string;
    title: string;
    description: string;
}

interface Props {
    heading: string;
    subheading: string;
}

const { heading, subheading } = Astro.props;

const featuresArray = [
    {
        title: "The Keyword Drain",
        description:
            "Ad agencies love broad keywords. They spend your budget fast. I stop this. I dig into your search terms. I cut the fake traffic. I make sure every dollar targets real buyers.",
        icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>',
    },
    {
        title: "The Fake Pixel",
        description:
            "Does your agency call a simple page view a conversion? I fix that. I rebuild your tracking from the ground up. I make sure your data shows real revenue. No more fake numbers.",
        icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>',
    },
    {
        title: "High-Trust Conversion",
        description:
            "Selling a shirt is easy. Selling financial advice, legal help, or consulting is hard. I build systems that sell complex, invisible services. I turn cold traffic into high-ticket clients.",
        icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>',
    },
    {
        title: "The Landing Page Fix",
        description:
            "Good ads cannot save a bad website. I fix the pages that kill your sales. I rewrite the words. I remove the friction. I make it simple for a good lead to hand you their money.",
        icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"></path>',
    },
    {
        title: "Ruthless Ad Testing",
        description:
            "Ugly ads fail. But pretty ads with no clear message fail too. I build ads that grab attention and force action. Then we test them. We keep the winners and kill the losers.",
        icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>',
    },
    {
        title: "Total System Audit",
        description:
            "I do not just look at your ads. I look at your whole machine. If your offer is weak, I will tell you. If your pricing is wrong, we fix it. I make sure the whole system makes money.",
        icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>',
    },
];
---

<section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-left max-w-3xl mb-16">
            <p class="text-3xl font-extrabold text-gray-900 sm:text-4xl mb-4">
                {heading}
            </p>
            <h2
                class="text-sm text-teal-600 font-bold tracking-wide uppercase mb-3"
            >
                {subheading}
            </h2>
            <div class="w-20 h-1 bg-orange-500 mt-4"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {
                featuresArray.map((feature: Feature) => (
                    <div class="relative p-6 bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow duration-300">
                        <div class="w-12 h-12 bg-teal-50 rounded-lg flex items-center justify-center text-teal-600 mb-4">
                            <svg
                                class="w-6 h-6"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                set:html={feature.icon}
                            />
                        </div>
                        <h3 class="text-lg font-bold text-gray-900 mb-2">
                            {feature.title}
                        </h3>
                        <p class="text-gray-500 text-base leading-relaxed">
                            {feature.description}
                        </p>
                    </div>
                ))
            }
        </div>
    </div>
</section>
