---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Apply - Jenkins Digital</title>
    </head>
    <body class="bg-gray-50 min-h-screen flex flex-col font-sans">
        <!-- Header / Logo -->
        <div class="w-full max-w-3xl mx-auto px-4 pt-10 pb-6">
            <a
                href="/"
                class="text-2xl font-bold text-teal-600 tracking-tight hover:opacity-80 transition-opacity"
            >
                Jenkins Digital
            </a>
        </div>

        <!-- Form Container -->
        <main class="max-w-3xl mx-auto w-full px-4 pb-16 flex-grow">
            <iframe
                data-tally-src="https://tally.so/embed/b5LX9Z?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1"
                loading="lazy"
                width="100%"
                height="1094"
                frameborder="0"
                marginheight="0"
                marginwidth="0"
                title="Jenkins Digital Intake"></iframe>
            <script is:inline>
                var d = document,
                    w = "https://tally.so/widgets/embed.js",
                    v = function () {
                        "undefined" != typeof Tally
                            ? Tally.loadEmbeds()
                            : d
                                  .querySelectorAll(
                                      "iframe[data-tally-src]:not([src])",
                                  )
                                  .forEach(function (e) {
                                      e.src = e.dataset.tallySrc;
                                  });
                    };
                if ("undefined" != typeof Tally) v();
                else if (d.querySelector('script[src="' + w + '"]') == null) {
                    var s = d.createElement("script");
                    ((s.src = w),
                        (s.onload = v),
                        (s.onerror = v),
                        d.body.appendChild(s));
                }
            </script>
        </main>
    </body>
</html>
